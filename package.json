{
  "name": "n8n-nodes-minimark",
  "version": "1.0.0",
  "description": "n8n node for Minimark utilities",
  "license": "MIT",
  "homepage": "https://github.com/iamprompt/n8n-nodes-minimark",
  "keywords": [
    "n8n-community-node-package",
    "minimark",
    "markdown",
    "ast"
  ],
  "author": {
    "name": "Supakarn Laorattanakul",
    "email": "opensource@iamprompt.me"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iamprompt/n8n-nodes-minimark.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "nodes": [
      "dist/nodes/Minimark/Minimark.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "minimark": "^1.0.0",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
